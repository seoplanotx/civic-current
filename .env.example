# =============================================================================
# Civic Current — environment configuration
# =============================================================================
# Copy this file to `.env.local` for local development, and set the same vars
# in the Vercel project dashboard for production.
#
# The app gracefully degrades when these are not set:
#   - No Clerk key  → anonymous mode, local-save only, no purchases possible
#   - No Stripe key → /api/checkout returns 500; UpgradeModal surfaces error
#   - No KV creds   → entitlements never persist; cloud save falls back to local
# =============================================================================

# -----------------------------------------------------------------------------
# Clerk (https://dashboard.clerk.com)
# -----------------------------------------------------------------------------
# Frontend publishable key (safe to expose in client bundle)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# Backend secret key (server-side only — never expose)
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Stripe (https://dashboard.stripe.com)
# -----------------------------------------------------------------------------
# Secret API key (server-side only)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# Webhook signing secret (from your Stripe webhook endpoint config)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Price ID for the one-time $14.99 premium unlock product
STRIPE_PRICE_PREMIUM_UNLOCK=price_xxxxxxxxxxxxxxxxxxxx

# Price ID for the recurring $4.99/mo "Mayor's Office" subscription.
# IMPORTANT: this MUST be a recurring (subscription) price in Stripe — a
# one-time price will fail the subscription-mode Checkout session. Without it
# set, /api/checkout/subscription returns 500 and the Mayor's Office modal
# surfaces the error.
STRIPE_PRICE_MAYORS_OFFICE=price_xxxxxxxxxxxxxxxxxxxx

# Price IDs for the one-time content packs (shown in the in-game Shop).
# Each must match a Stripe Price; the env var name is declared per pack in
# src/content/catalog.ts (`stripePriceEnv`). Without these set, that pack's
# checkout returns 500 and the Shop shows an error on Buy.
STRIPE_PRICE_PACK_THROWBACK=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PACK_TOMORROWS_CITY=price_xxxxxxxxxxxxxxxxxxxx

# Price IDs for the one-time cosmetic board themes (shown in the in-game
# Themes shop). Each must match a Stripe Price; the env var name is declared
# per theme in src/content/cosmetics/catalog.ts (`stripePriceEnv`). Without
# these set, that theme's checkout returns 500 and the shop shows an error on
# Buy. Equip/unequip still works for already-owned themes.
STRIPE_PRICE_COSMETIC_NOIR=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_COSMETIC_VAPORWAVE=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_COSMETIC_SOLARPUNK=price_xxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Vercel KV (https://vercel.com/dashboard/stores)
# -----------------------------------------------------------------------------
# Auto-populated by Vercel when you connect a KV store to the project.
# For local dev, copy the values from the KV store's `.env.local` tab.
KV_REST_API_URL=https://example-kv.upstash.io
KV_REST_API_TOKEN=xxxxxxxxxxxxxxxxxxxx
KV_REST_API_READ_ONLY_TOKEN=xxxxxxxxxxxxxxxxxxxx
KV_URL=redis://default:xxxxxxxxxxxxxxxxxxxx@example-kv.upstash.io:6379
